library(tidyverse)
library(caret)
library(pROC)
medical <- read.csv("medical_care.csv", stringsAsFactors = TRUE)
dim(medical)
head(medical)
# Kiểm tra phân phối biến mục tiêu
table(medical$UCURNINS)
prop.table(table(medical$UCURNINS))
set.seed(42)
# Tạo chỉ số cho tập training (70%)
train_idx <- createDataPartition(medical$UCURNINS, p = 0.7, list = FALSE)
train_data <- medical[train_idx, ]
test_data  <- medical[-train_idx, ]
cat("Kích thước tập train:", nrow(train_data), "\n")
cat("Kích thước tập test: ", nrow(test_data),  "\n")
# Kiểm tra tỷ lệ lớp trong từng tập
prop.table(table(train_data$UCURNINS))
prop.table(table(test_data$UCURNINS))
library(tidyverse)
library(rpart)        # Xây dựng Decision Tree (CART)
library(rpart.plot)   # Visualize cây đẹp hơn
install.packages(c("rpart", "rpart.plot", "caret", "tidymodels",
"pROC", "tidyverse", "vip"))
install.packages(c("randomForest", "ranger", "caret",
"vip", "pROC", "tidyverse", "patchwork"))
library(caret)
library(randomForest)
train_data <- read.csv("adult_train.csv", stringsAsFactors = FALSE)
test_data  <- read.csv("adult_test.csv", stringsAsFactors = FALSE)
# Tiền xử lý
train_data$Target <- trimws(train_data$Target)
test_data$Target  <- trimws(test_data$Target)
train_data$Target <- gsub("\\.", "", train_data$Target)
test_data$Target  <- gsub("\\.", "", test_data$Target)
train_data$Target <- gsub("<=50K", "Low", train_data$Target)
train_data$Target <- gsub(">50K", "High", train_data$Target)
test_data$Target <- gsub("<=50K", "Low", test_data$Target)
test_data$Target <- gsub(">50K", "High", test_data$Target)
# Convert thành factor
train_data$Target <- as.factor(train_data$Target)
test_data$Target  <- factor(test_data$Target, levels = levels(train_data$Target))
# Convert chữ thành factor
train_data[] <- lapply(train_data, function(x) {
if (is.character(x)) as.factor(x) else x
})
test_data[] <- lapply(test_data, function(x) {
if (is.character(x)) as.factor(x) else x
})
# CV setup
set.seed(42)
ctrl <- trainControl(
method = "repeatedcv",
number = 5,
repeats = 20,
classProbs = TRUE,
savePredictions = "final"
)
# Train RF
model_rf <- train(
Target ~ .,
data = train_data,
method = "rf",
trControl = ctrl,
tuneGrid = data.frame(mtry = 3),
ntree = 200,
metric = "Accuracy"
)
library(caret)
library(randomForest)
train_data <- read.csv("adult_train.csv", stringsAsFactors = FALSE)
test_data  <- read.csv("adult_test.csv", stringsAsFactors = FALSE)
# Tiền xử lý
train_data$Target <- trimws(train_data$Target)
test_data$Target  <- trimws(test_data$Target)
train_data$Target <- gsub("\\.", "", train_data$Target)
test_data$Target  <- gsub("\\.", "", test_data$Target)
train_data$Target <- gsub("<=50K", "Low", train_data$Target)
train_data$Target <- gsub(">50K", "High", train_data$Target)
test_data$Target <- gsub("<=50K", "Low", test_data$Target)
test_data$Target <- gsub(">50K", "High", test_data$Target)
# Convert thành factor
train_data$Target <- as.factor(train_data$Target)
test_data$Target  <- factor(test_data$Target, levels = levels(train_data$Target))
# Convert chữ thành factor
train_data[] <- lapply(train_data, function(x) {
if (is.character(x)) as.factor(x) else x
})
test_data[] <- lapply(test_data, function(x) {
if (is.character(x)) as.factor(x) else x
})
# CV setup
ctrl <- trainControl(
method = "repeatedcv",
number = 5,
repeats = 3,
verboseIter = TRUE
)
model_rf <- train(
Target ~ .,
data = train_data,
method = "ranger",
trControl = ctrl,
tuneGrid = data.frame(
mtry = 3,
splitrule = "gini",
min.node.size = 1
),
num.trees = 100,
metric = "Accuracy")
print(model_rf)
library(caret)
library(randomForest)
library(ranger)
train_data <- read.csv("adult_train.csv", stringsAsFactors = FALSE)
test_data  <- read.csv("adult_test.csv", stringsAsFactors = FALSE)
# Tiền xử lý
train_data$Target <- trimws(train_data$Target)
test_data$Target  <- trimws(test_data$Target)
train_data$Target <- gsub("\\.", "", train_data$Target)
test_data$Target  <- gsub("\\.", "", test_data$Target)
train_data$Target <- gsub("<=50K", "Low", train_data$Target)
train_data$Target <- gsub(">50K", "High", train_data$Target)
test_data$Target <- gsub("<=50K", "Low", test_data$Target)
test_data$Target <- gsub(">50K", "High", test_data$Target)
# Convert thành factor
train_data$Target <- as.factor(train_data$Target)
test_data$Target  <- factor(test_data$Target, levels = levels(train_data$Target))
# Convert chữ thành factor
train_data[] <- lapply(train_data, function(x) {
if (is.character(x)) as.factor(x) else x
})
test_data[] <- lapply(test_data, function(x) {
if (is.character(x)) as.factor(x) else x
})
# CV setup
ctrl <- trainControl(
method = "repeatedcv",
number = 5,
repeats = 3,
verboseIter = TRUE
)
model_rf <- train(
Target ~ .,
data = train_data,
method = "ranger",
trControl = ctrl,tuneLength = 5,
tuneGrid = data.frame(
mtry = 3,
splitrule = "gini",
min.node.size = 1
),
num.trees = 100,
metric = "Accuracy"
)
print(model_rf)
