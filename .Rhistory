library(readr)
library(dplyr)
if (!require(caret)) install.packages("caret")
if (!require(pROC)) install.packages("pROC")
library(caret)
library(pROC)
# Read data
data <- read_csv("water_potability.csv")
View(data)
# Overview
head(data)
str(data)
summary(data)
colSums(is.na(data))
# Preprocessing: replace NA in predictors with column mean
data <- data %>%
mutate(across(-Potability, ~ ifelse(is.na(.), mean(., na.rm = TRUE), .)))
# Check again
colSums(is.na(data))
# Split data into train and test
set.seed(123)
train_idx <- sample(1:nrow(data), 0.8 * nrow(data))
train_data <- data[train_idx, ]
test_data  <- data[-train_idx, ]
cat("\nTrainn:", dim(train_data))
cat("\nTest:", dim(test_data), "\n")
# Logistic regression model
model <- glm(Potability ~ .,
data = train_data,
family = binomial(link = "logit"))
# Model summary
summary_model <- summary(model)
print(summary_model)
# Predict probabilities
prob_pred <- predict(model, newdata = test_data, type = "response")
# Convert probabilities to class labels
pred_class <- ifelse(prob_pred > 0.5, 1, 0)
# Confusion matrix
conf_mat <- confusionMatrix(
factor(pred_class),
factor(test_data$Potability)
)
print(conf_mat)
# Accuracy
accuracy <- mean(pred_class == test_data$Potability)
cat("\nAccuracy:", accuracy, "\n")
# ROC and AUC
roc_obj <- roc(test_data$Potability, prob_pred)
plot(roc_obj, main = "ROC Curve for Logistic Regression")
auc_value <- auc(roc_obj)
cat("\nAUC:", auc_value, "\n")
conf_mat <- confusionMatrix(
factor(pred_class),
factor(test_data$Potability)
)
print(conf_mat)
library(readr)
library(dplyr)
library(caret)
library(pROC)
# Read data
data <- read_csv("water_potability.csv")
View(data)
# Overview
head(data)
str(data)
summary(data)
colSums(is.na(data))
# Preprocessing: replace NA in predictors with column mean
data <- data %>%
mutate(across(-Potability, ~ ifelse(is.na(.), mean(., na.rm = TRUE), .)))
# Check again
colSums(is.na(data))
# Split data into train and test
set.seed(123)
train_idx <- sample(1:nrow(data), 0.8 * nrow(data))
train_data <- data[train_idx, ]
test_data  <- data[-train_idx, ]
cat("\nTrainn:", dim(train_data))
cat("\nTest:", dim(test_data), "\n")
# Logistic regression model
model <- glm(Potability ~ .,
data = train_data,
family = binomial(link = "logit"))
# Model summary
summary_model <- summary(model)
print(summary_model)
# Predict probabilities
prob_pred <- predict(model, newdata = test_data, type = "response")
# Convert probabilities to class labels
pred_class <- ifelse(prob_pred > 0.5, 1, 0)
# Evaluation
conf_matrix <- confusionMatrix(
factor(pred_class),
factor(test_data$Potability)
)
print(conf_matrix)
# Accuracy
accuracy <- mean(pred_class == test_data$Potability)
# Precision, Recall, F1
TP <- sum(pred_class == 1 & test_data$Potability == 1)
TN <- sum(pred_class == 0 & test_data$Potability == 0)
FP <- sum(pred_class == 1 & test_data$Potability == 0)
FN <- sum(pred_class == 0 & test_data$Potability == 1)
precision <- TP / (TP + FP)
recall    <- TP / (TP + FN)
f1_score  <- 2 * precision * recall / (precision + recall)
cat("\nAccuracy:", accuracy)
cat("\nPrecision:", precision)
cat("\nRecall:", recall)
cat("\nF1-score:", f1_score)
# (1) Distribution of pH
ggplot(data, aes(x = pH, fill = factor(Potability))) +
geom_density(alpha = 0.5) +
labs(title = "Distribution of pH by Potability",
fill = "Potability") +
theme_minimal()
